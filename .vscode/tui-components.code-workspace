{
  "folders": [
    {
      "path": ".."
    }
  ],
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Open Terminals",
        "command": "${command:terminals.runTerminals}",
        "type": "process",
        "runOptions": {
          "runOn": "folderOpen"
        }
      }
    ]
  },
  "settings": {
    "terminals.autorun": true,
    "terminals.terminals": [
      {
        "name": "Agent Fleet",
        "color": "terminal.ansiWhite",
        "icon": "robot",
        "commands": [
          "source .env.local && af-worker-fleet -p tui-components"
        ]
      },
      {
        "name": "Agent Log Watch",
        "color": "terminal.ansiWhite",
        "icon": "search",
        "commands": [
          "source .env.local && af-analyze-logs --follow"
        ],
        "split": "Agent Fleet"
      },
      {
        "name": "TUI Components Dev",
        "color": "terminal.ansiYellow",
        "icon": "sparkle",
        "commands": [
          "make test"
        ]
      },
      {
        "name": "Claude TC #1",
        "color": "terminal.ansiBrightGreen",
        "icon": "squirrel",
        "commands": [
          "WT=$(./scripts/create-worktree.sh tc-1) && cd $WT && claude --dangerously-skip-permissions --remote-control"
        ]
      },
      {
        "name": "Claude TC #2",
        "color": "terminal.ansiBrightCyan",
        "icon": "squirrel",
        "commands": [
          "WT=$(./scripts/create-worktree.sh tc-2) && cd $WT && claude --dangerously-skip-permissions --remote-control"
        ]
      }
    ]
  },
  "extensions": {
    "recommendations": [
      "golang.go",
      "fabiospampinato.vscode-terminals"
    ]
  }
}
